
import java.util.*;
public class Student_System {
    private ArrayList <Student> studentList;
    public System (){
        this.studentList = new ArrayList<Student>();
    }

    // to add student
    public void addStudent(String name, int ID, String college, String major){
        studentList.add(new Student(name, ID, college,major));
    }

    //to find the student
    public Student findStudent(int id) {
        for (Student s: studentList) {
            if (s.getID() == id) {
                return s;
            }
        }
        return null;
    }

    //to edit student info
    public Student editInfo(int ID, String newName, String newCollege, String newMajor){
        Student s = findStudent(ID);
        if(s != null){
            s.setName(newName);
            s.setCollege(newCollege);
            s.setMajor(newMajor);
            return s;
        }
        return null;
    }

    //to delete student
    public Student deleteStudent(int ID){
        Student s = findStudent(ID);
        if (s != null) {
            studentList.remove(s);
            return s;
        }
        return null ;
    }

    //to see the students in the same collage
    public String sameCollage(String collage){
        String result = "";
        for (Student s: studentList){
            if(collage.equals(s.getCollege()))
                result += s.toString() + "\n";
            return result;
        }
        return "No students found.";
    }

    // to see all students or the whole list
    public String allStudents() {
        if (!(studentList.isEmpty())) {
            String result = "";
            for (Student s: studentList){
                result += s.toString() + "\n";
            }
            return result;
        }
        return "No students found.";
    }
}
